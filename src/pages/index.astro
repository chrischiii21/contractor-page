---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
---

<Layout>
	<Navbar />
	<main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 mt-20 lg:mt-30">
		<h1
			class="font-display text-[2.25rem] font-bold text-midnight-navy mb-4 leading-snug tracking-tight"
		>
			Welcome to CoolAir
		</h1>
		<p class="text-machinist-gray text-[1.125rem] leading-relaxed">
			Your trusted partner for HVAC and plumbing services.
		</p>
	</main>
</Layout>
