---
import Layout from "../layouts/Layout.astro";
---

<Layout>
	<main>
		<h1>Welcome to Astro</h1>
		<p>Start building your project here.</p>
	</main>
</Layout>

<style>
	main {
		max-width: 800px;
		margin: 0 auto;
		padding: 2rem;
	}

	h1 {
		color: #333;
		margin-bottom: 1rem;
	}

	p {
		color: #666;
		line-height: 1.6;
	}
</style>
