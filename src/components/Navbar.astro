---
// Navbar component with dropdown menus
import logo from "../assets/logo.png";
---

<nav
    class="w-full bg-midnight-navy text-parchment-white fixed top-0 left-0 right-0 z-50"
>
    <!-- Top bar with contact info and social links -->
    <div
        id="top-bar"
        class="bg-[#1a2d4a] border-b border-steel-pewter/20 hidden lg:block transition-all duration-300"
    >
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center h-10 text-sm">
                <div class="flex items-center gap-6">
                    <a
                        href="tel:+9295535296"
                        class="flex items-center gap-2 hover:text-helios-orange transition-colors"
                    >
                        <svg
                            class="w-4 h-4"
                            fill="currentColor"
                            viewBox="0 0 20 20"
                        >
                            <path
                                d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"
                            ></path>
                        </svg>
                        <span>+929 553 5296</span>
                    </a>
                    <a
                        href="mailto:contact@coolair.com"
                        class="flex items-center gap-2 hover:text-helios-orange transition-colors"
                    >
                        <svg
                            class="w-4 h-4"
                            fill="currentColor"
                            viewBox="0 0 20 20"
                        >
                            <path
                                d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"
