                </div>
                <div class="flex items-center gap-3">
                    <a
                        href="#"
                        class="hover:text-helios-orange transition-colors"
                        aria-label="Facebook"
                    >
                        <svg
                            class="w-4 h-4"
                            fill="currentColor"
                            viewBox="0 0 24 24"
